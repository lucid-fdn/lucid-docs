{
  "$schema": "./schemas/docs-automation.schema.json",
  "version": 1,
  "generatedHeader": "<!-- generated by scripts/rebuild-public-sources.py; do not edit manually -->",
  "tabOrder": [
    "Get Started",
    "Build & Deploy",
    "How Lucid Works",
    "Core Concepts",
    "Gateway",
    "API & SDK",
    "On-Chain",
    "More",
    "Knowledge Base",
    "Architecture Reference",
    "Gateway SDK"
  ],
  "sources": [
    {
      "id": "lucid-wiki",
      "repo": "lucid-fdn/lucid-wiki",
      "localPath": "../lucid-wiki",
      "rootEnv": "LUCID_WIKI_ROOT",
      "visibility": "private",
      "publicSafe": true,
      "adapter": "gitbook-summary",
      "summary": "SUMMARY.md",
      "outputPrefix": "knowledge",
      "navigationTab": "Knowledge Base",
      "navigationOrder": 7,
      "exclude": [
        "disclaimer.md"
      ]
    },
    {
      "id": "lucid-l2-modules",
      "repo": "lucid-fdn/Lucid-L2",
      "localPath": "../Lucid-L2",
      "rootEnv": "LUCID_L2_ROOT",
      "visibility": "public",
      "publicSafe": true,
      "adapter": "markdown-tree",
      "sourceGlobs": [
        "docs/modules/**/*.md",
        "docs/reference/**/*.md"
      ],
      "outputPrefix": "reference/lucid-l2",
      "navigationTab": "Architecture Reference",
      "navigationOrder": 8,
      "groupBy": "first-directory",
      "exclude": [
        "docs/modules/contracts/**/Mock*.md"
      ]
    },
    {
      "id": "lucid-cloud-gateway-sdk",
      "repo": "lucid-fdn/lucid-cloud",
      "localPath": "../lucid-cloud",
      "rootEnv": "LUCID_CLOUD_ROOT",
      "visibility": "private",
      "publicSafe": true,
      "adapter": "sdk-namespace-tree",
      "sourceRoot": "sdk/lucid-gateway-typescript/docs/sdks",
      "outputPrefix": "reference/gateway-sdk",
      "linkMode": "github",
      "navigationTab": "Gateway SDK",
      "navigationOrder": 9
    },
    {
      "id": "lucid-cloud-internal-inventory",
      "repo": "lucid-fdn/lucid-cloud",
      "localPath": "../lucid-cloud",
      "rootEnv": "LUCID_CLOUD_ROOT",
      "visibility": "private",
      "publicSafe": false,
      "adapter": "inventory-only",
      "sourceGlobs": [
        "**/*.md",
        "**/*.mdx"
      ],
      "exclude": [
        "sdk/lucid-gateway-typescript/docs/**",
        "node_modules/**",
        "dist/**",
        "build/**"
      ]
    }
  ]
}
